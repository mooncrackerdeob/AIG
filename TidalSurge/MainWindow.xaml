<Window
    x:Class="TidalSurge.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:TidalSurge"
    mc:Ignorable="d"
    Title="Tidal.surge"
    Width="1280" Height="860">
    <Grid Background="{StaticResource BgBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Dynamic Island Top Bar -->
        <Grid Grid.Row="0" Margin="0,16,0,8">
            <Grid HorizontalAlignment="Center">
                <Border CornerRadius="16" Background="{StaticResource PanelGlassBrush}"
                        BorderBrush="{StaticResource PanelStrokeBrush}" BorderThickness="1"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Status -->
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse Width="12" Height="12" Fill="{StaticResource AccentFireBrush}"/>
                            <TextBlock Text="ENABLED" Style="{StaticResource CaptionText}"/>
                        </StackPanel>
                        <!-- Metrics -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
                            <TextBlock Text="Ping: 23 ms" Style="{StaticResource CaptionText}"/>
                            <TextBlock Text="CPU: 17%" Style="{StaticResource CaptionText}"/>
                            <TextBlock Text="GPU: 41%" Style="{StaticResource CaptionText}"/>
                        </StackPanel>
                        <!-- User -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE77B;"/>
                            <TextBlock Text="goose_w2 · Expiry: 3817 days" Style="{StaticResource CaptionText}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Two-pane layout: Left Navigation + Content Frame -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Nav -->
            <StackPanel Grid.Column="0" Background="{StaticResource BgElevatedBrush}">
                <TextBlock Text="Tidal.surge" Margin="20,16,0,8" Style="{StaticResource TitleText}"/>
                <ListView x:Name="NavList" SelectionChanged="OnNavSelectionChanged" Margin="8" SelectionMode="Single">
                    <ListViewItem Content="Master Control"/>
                    <ListViewItem Content="Macros"/>
                    <ListViewItem Content="Custom Macros (AI)"/>
                    <ListViewItem Content="Settings"/>
                </ListView>
            </StackPanel>

            <!-- Content -->
            <Frame x:Name="ContentFrame" Grid.Column="1" Margin="24"/>
        </Grid>
    </Grid>
</Window>

