<Page
    x:Class="TidalSurge.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource BgBaseBrush}" Padding="8,0,8,8">
        <StackPanel Spacing="16">
            <TextBlock Text="Master Control" Style="{StaticResource HeaderText}"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ToggleSwitch Header="Global Enable"/>
                <ToggleSwitch Header="Game Detection"/>
            </StackPanel>
            <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="12" Padding="16">
                <TextBlock Text="Quick Stats" Style="{StaticResource BodyText}"/>
            </Border>
        </StackPanel>
    </Grid>
</Page>

