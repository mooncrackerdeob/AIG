<Page
    x:Class="TidalSurge.Views.SplashPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="{StaticResource BgBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Spacing="16">
            <TextBlock Text="Tidal.surge" Style="{StaticResource TitleText}" HorizontalAlignment="Center"/>
            <ProgressRing Width="32" Height="32" IsActive="True"/>
            <TextBlock Text="Initializing…" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
    
</Page>

