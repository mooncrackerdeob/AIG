<Page
    x:Class="TidalSurge.Views.MacrosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource BgBaseBrush}" Padding="0,0,0,8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Macro List -->
        <ListView x:Name="MacroList" Grid.Column="0" SelectionChanged="OnMacroSelected" Margin="0,0,8,0">
            <ListViewItem Content="Backdash Cancel"/>
            <ListViewItem Content="Twisted Macro"/>
            <ListViewItem Content="Instant Lethal"/>
            <ListViewItem Content="Loop Dash"/>
        </ListView>

        <!-- Detail Panel -->
        <ScrollViewer Grid.Column="1" Margin="8,0,0,0">
            <StackPanel Spacing="16">
                <TextBlock x:Name="MacroTitle" Text="Select a macro" Style="{StaticResource HeaderText}"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ToggleSwitch x:Name="EnableToggle" Header="Enable"/>
                    <TextBox x:Name="HotkeyInput" PlaceholderText="Set Hotkey (e.g., F8)" Width="200" Style="{StaticResource InputStyle}"/>
                </StackPanel>

                <!-- Example controls -->
                <StackPanel>
                    <TextBlock Text="Smoothness" Style="{StaticResource BodyText}"/>
                    <Slider Minimum="0" Maximum="100" Value="60"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Turn Angle (°)" Style="{StaticResource BodyText}"/>
                    <Slider Minimum="0" Maximum="360" Value="90"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Delay (ms)" Style="{StaticResource BodyText}"/>
                    <Slider Minimum="0" Maximum="500" Value="120"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Test Macro"/>
                    <Button Content="Apply" Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

