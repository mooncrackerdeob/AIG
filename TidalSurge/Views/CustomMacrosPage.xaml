<Page
    x:Class="TidalSurge.Views.CustomMacrosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource BgBaseBrush}" Padding="8">
        <StackPanel Spacing="16">
            <TextBlock Text="Custom Macros (AI)" Style="{StaticResource HeaderText}"/>
            <TextBox x:Name="PromptInput" AcceptsReturn="True" Height="120" PlaceholderText="Describe a combo or technique…" Style="{StaticResource InputStyle}"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Upload a Video Clip"/>
                <Button Content="Generate Macro with AI" Style="{StaticResource PrimaryButtonStyle}" Click="OnGenerateClick"/>
                <ProgressBar x:Name="AiProgress" Width="200" Visibility="Collapsed"/>
            </StackPanel>
            <TextBlock x:Name="AiStatus" Style="{StaticResource CaptionText}"/>
            <ItemsControl x:Name="GeneratedList"/>
        </StackPanel>
    </Grid>
</Page>

