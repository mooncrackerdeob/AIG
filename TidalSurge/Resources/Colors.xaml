<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Color tokens -->
    <Color x:Key="BgBase">#0B0F14</Color>
    <Color x:Key="BgElevated">#0E141B</Color>
    <Color x:Key="TextPrimary">#E7EEF7</Color>
    <Color x:Key="TextSecondary">#A9B6C6</Color>
    <Color x:Key="AccentFire">#FF6B3D</Color>
    <Color x:Key="AccentCyan">#22E6E6</Color>
    <Color x:Key="PanelStroke">#26FFFFFF</Color>

    <!-- Brush tokens -->
    <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}"/>
    <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="AccentFireBrush" Color="{StaticResource AccentFire}"/>
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource AccentCyan}"/>
    <SolidColorBrush x:Key="PanelStrokeBrush" Color="{StaticResource PanelStroke}"/>
    <SolidColorBrush x:Key="PanelGlassBrush" Color="#10FFFFFF"/>
</ResourceDictionary>

